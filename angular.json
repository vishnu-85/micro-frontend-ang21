            }
          },
          "defaultConfiguration": "development"
        }
      }
    },

    "parent-dashboard": {
      "projectType": "application",
      "root": "projects/parent-dashboard",
      "sourceRoot": "projects/parent-dashboard/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-architects/native-federation:build",
          "options": {},
          "configurations": {
