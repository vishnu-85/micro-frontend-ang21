            "assets": [
              "projects/institute-dashboard/src/favicon.ico",
              "projects/institute-dashboard/src/assets"
            ],
            "styles": [
              "projects/institute-dashboard/src/styles.css"
            ],
            "polyfills": [
              "es-module-shims"
            ]
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve-original": {
